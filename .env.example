# Beispiel-Konfiguration. KEINE echten Secrets hier!

# Shopify Theme Access Token (Theme Access App im AMG Shop erzeugt)
SHOPIFY_CLI_THEME_TOKEN=shptka_HIER_TOKEN_EINSETZEN

# Storefront-Passwort (nur falls AMG Shop einen Passwortschutz hat;
# Live-Stores meist ohne)
# SHOPIFY_STOREFRONT_PASSWORD=

# Optional fuer Shopify MCP (Admin-API):
# SHOPIFY_STORE_URL=zjyfg5-ya.myshopify.com
# SHOPIFY_ADMIN_TOKEN=shpat_HIER_TOKEN_EINSETZEN
