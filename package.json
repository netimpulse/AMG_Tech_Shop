{
  "name": "amg-tech-shop",
  "version": "0.1.0",
  "private": true,
  "description": "AMG Tech Shop — Shopify Theme mit Visual-QA-Workflow",
  "scripts": {
    "theme:check": "shopify theme check",
    "theme:push:dev": "shopify theme push -e development",
