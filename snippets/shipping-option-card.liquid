{% comment %}
  Snippet: Einzelne Versandoption (DHL / DPD / Go!)
  Verwendung:
    {% render 'shipping-option-card',
      carrier_id: 'dhl',
      carrier_name: 'DHL Express',
      carrier_price: '29,90 €',
      carrier_price_raw: '29.90',
      carrier_details_html: '<ul><li>Lieferung in 1-2 Werktagen</li></ul>',
      block: block
    %}
{% endcomment %}

<div class="te-carrier" data-carrier="{{ carrier_id }}" data-carrier-price="{{ carrier_price_raw }}" {{ block.shopify_attributes }}>
  <div class="te-carrier__header" role="button" tabindex="0"
       aria-expanded="false"
       aria-label="{{ carrier_name }} – {{ carrier_price }}">
    <span class="te-carrier__radio" aria-hidden="true"></span>
    <span class="te-carrier__name">{{ carrier_name }}</span>
    <span class="te-carrier__price">{{ carrier_price }}</span>
    <svg class="te-carrier__chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M5 7.5L10 12.5L15 7.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
  <div class="te-carrier__details" role="region" aria-label="Lieferkonditionen {{ carrier_name }}">
    <div class="te-carrier__details-inner">
      {{ carrier_details_html }}
    </div>
  </div>
</div>
