{%- assign _fs = section.settings.block_font_size -%}
{%- assign _fc = section.settings.block_font_color -%}
{%- assign _ff = section.settings.block_font_family -%}
{%- assign _bg = section.settings.block_bg_color -%}
{%- assign _heading_fs = section.settings.heading_font_size -%}
{%- assign _heading_fc = section.settings.heading_font_color -%}
{%- assign _question_fs = section.settings.question_font_size -%}
{%- assign _question_fc = section.settings.question_font_color -%}
{%- assign _answer_fs = section.settings.answer_font_size -%}
{%- assign _answer_fc = section.settings.answer_font_color -%}
{%- assign _icon_color = section.settings.icon_color -%}
{%- assign _gap = section.settings.faq_gap -%}

{%- if _fs > 0 or _fc != blank or _ff or _bg != blank or _heading_fs > 0 or _heading_fc != blank or _question_fs > 0 or _question_fc != blank or _answer_fs > 0 or _answer_fc != blank or _icon_color != blank or _gap > 0 -%}
<style>
  #shopify-section-{{ section.id }} .sec-inner {
    {%- if _fs > 0 -%}font-size: {{ _fs }}px;{%- endif -%}
    {%- if _fc != blank -%}color: {{ _fc }};{%- endif -%}
    {%- if _ff -%}font-family: {{ _ff.family }}, {{ _ff.fallback_families }};font-weight: {{ _ff.weight }};font-style: {{ _ff.style }};{%- endif -%}
    {%- if _bg != blank -%}background: {{ _bg }};{%- endif -%}
  }
  {%- if _heading_fs > 0 or _heading_fc != blank -%}
  #shopify-section-{{ section.id }} .mfa__heading {
    {%- if _heading_fs > 0 -%}font-size: {{ _heading_fs }}px;{%- endif -%}
    {%- if _heading_fc != blank -%}color: {{ _heading_fc }};{%- endif -%}
  }
  {%- endif -%}
  {%- if _question_fs > 0 or _question_fc != blank -%}
  #shopify-section-{{ section.id }} .mfa__question {
    {%- if _question_fs > 0 -%}font-size: {{ _question_fs }}px;{%- endif -%}
    {%- if _question_fc != blank -%}color: {{ _question_fc }};{%- endif -%}
  }
  {%- endif -%}
  {%- if _answer_fs > 0 or _answer_fc != blank -%}
  #shopify-section-{{ section.id }} .mfa__answer {
    {%- if _answer_fs > 0 -%}font-size: {{ _answer_fs }}px;{%- endif -%}
    {%- if _answer_fc != blank -%}color: {{ _answer_fc }};{%- endif -%}
  }
  {%- endif -%}
  {%- if _icon_color != blank -%}
  #shopify-section-{{ section.id }} .mfa__chevron {
    stroke: {{ _icon_color }};
  }
  {%- endif -%}
  {%- if _gap > 0 -%}
  #shopify-section-{{ section.id }} .mfa__item {
    margin-bottom: {{ _gap }}px;
  }
  {%- endif -%}
</style>
{%- endif -%}

{{ 'mod-faq-accordion.css' | asset_url | stylesheet_tag }}
{%- assign s = section.settings -%}
<div class="mfa sec-inner" style="padding:{{ s.padding_y }}px 0;{%- if s.section_bg != blank -%}background:{{ s.section_bg }};{%- endif -%}">
  <div class="page-width mfa__inner">
    {%- if s.heading != blank -%}<h2 class="mfa__heading">{{ s.heading }}</h2>{%- endif -%}
    {%- if s.subheading != blank -%}<p class="mfa__sub">{{ s.subheading }}</p>{%- endif -%}
    <div class="mfa__list">
      {%- for block in section.blocks -%}
        <details class="mfa__item" {{ block.shopify_attributes }} id="block-{{ block.id }}">
          <summary class="mfa__question">
            <span>{{ block.settings.question }}</span>
            <svg class="mfa__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="mfa__answer rte">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
