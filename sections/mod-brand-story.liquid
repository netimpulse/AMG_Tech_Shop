          "min": 0,
          "max": 72,
          "step": 1,
          "default": 0,
          "unit": "px",
          "info": "0 = Standard"
        },
        {
          "type": "color",
          "id": "block_font_color",
          "label": "Schriftfarbe"
        },
        {
          "type": "font_picker",
          "id": "block_font_family",
          "label": "Schriftart",
          "default": "assistant_n4"
        },
        {
          "type": "color_background",
          "id": "block_bg_color",
          "label": "Hintergrundfarbe"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mod: Markengeschichte",
      "blocks": [
        {
          "type": "milestone",
          "settings": {
            "year": "2020",
            "title": "Gruendung",
