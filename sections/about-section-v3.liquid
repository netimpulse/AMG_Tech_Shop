      "step": 5,
      "unit": "%",
      "default": 85
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Bild Seitenverhältnis",
      "options": [
        {
          "value": "auto",
          "label": "Original"
        },
        {
          "value": "4/3",
          "label": "4:3"
        },
        {
          "value": "16/9",
          "label": "16:9"
        },
        {
          "value": "1/1",
          "label": "1:1"
        }
      ],
      "default": "auto"
