{% comment %}
  Über Uns (Layout) – v3.2
  - Breite: Content jetzt links bündig und bis 1180px (wie oben)
  - Optional: Höhe an vorherigen Abschnitt angleichen
{% endcomment %}

{{ 'section-ueber-uns-layout-v3.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} {
    --background-color: {{ section.settings.background_color }};
    --section-padding-top: {{ section.settings.section_padding_top }}px;
    --section-padding-bottom: {{ section.settings.section_padding_bottom }}px;

    --title-color: {{ section.settings.title_color }};
    --title-font-size: {{ section.settings.title_font_size }}px;
    --title-font-family: {{ section.settings.font_heading.family }}, {{ section.settings.font_heading.fallback_families }};

    --subtitle-color: {{ section.settings.subtitle_color }};
    --subtitle-font-size: {{ section.settings.subtitle_font_size }}px;

    --text-color: {{ section.settings.text_color }};
    --text-font-size: {{ section.settings.text_font_size }}px;
    --text-font-family: {{ section.settings.font_body.family }}, {{ section.settings.font_body.fallback_families }};

    --image-border-radius: {{ section.settings.image_border_radius }}px;
    --image-max-width: {{ section.settings.image_max_width }}%;
    --image-aspect-ratio: {{ section.settings.image_aspect_ratio }};

    --features-per-row: {{ section.settings.features_per_row }};
    --icon-size: {{ section.settings.icon_size }}px;
    --icon-color: {{ section.settings.icon_color }};
    --feature-title-color: {{ section.settings.feature_title_color }};

    --no-image-text-align: {{ section.settings.no_image_text_align }};

    /* Inhaltsbreite */
    --content-max-width: {{ section.settings.content_max_width | default: 1180 }}px;
  }
  #shopify-section-{{ section.id }} .sis-about__title { font-family: var(--title-font-family); }
  #shopify-section-{{ section.id }} .sis-about__subtitle { font-family: var(--title-font-family); }
  #shopify-section-{{ section.id }} .sis-about__description { font-family: var(--text-font-family); }
  #shopify-section-{{ section.id }} .sis-about__feature-title { font-family: var(--title-font-family); }
  #shopify-section-{{ section.id }} .sis-about__feature-description { font-family: var(--text-font-family); }
</style>

{%- liquid
  assign img_pos = section.settings.image_position
  assign show_image = section.settings.show_image
  assign has_image = false
  if section.settings.image != blank
    assign has_image = true
  endif
  assign actually_show_image = false
  if show_image and has_image
    assign actually_show_image = true
  endif

  assign enable_slider = section.settings.enable_image_slider
  assign slider_image_count = 1
  if enable_slider
    if section.settings.image_2 != blank
      assign slider_image_count = slider_image_count | plus: 1
    endif
    if section.settings.image_3 != blank
      assign slider_image_count = slider_image_count | plus: 1
    endif
    if section.settings.image_4 != blank
      assign slider_image_count = slider_image_count | plus: 1
    endif
    if section.settings.image_5 != blank
      assign slider_image_count = slider_image_count | plus: 1
    endif
  endif
  assign use_slider = false
  if enable_slider and actually_show_image and slider_image_count > 1
    assign use_slider = true
  endif

  assign title_html = section.settings.title_richtext
  if title_html == blank and section.settings.title != blank
    assign title_html = '<p>' | append: section.settings.title | append: '</p>'
  endif

  assign subtitle_html = section.settings.subtitle_richtext
  if subtitle_html == blank and section.settings.subtitle != blank
    assign subtitle_html = '<p>' | append: section.settings.subtitle | append: '</p>'
  endif

  assign float_mode = false
  if img_pos == 'left' or img_pos == 'right'
    assign float_mode = true
  endif
-%}

<div id="about-{{ section.id }}" class="sis-about-section">
  <div class="sis-about__container">

    <div class="
      sis-about__grid
      {% if float_mode %} sis-about__grid--float{% endif %}
      {% if img_pos == 'top' %} sis-about__grid--stack sis-about__grid--image-first{% endif %}
      {% if img_pos == 'bottom' %} sis-about__grid--stack sis-about__grid--image-last{% endif %}
      {% unless actually_show_image %} sis-about__grid--no-image{% endunless %}
    ">

      {%- if actually_show_image -%}
        {%- unless float_mode -%}
          <div class="sis-about__image sis-about__image--valign-{{ section.settings.image_vertical_align }}">
            {%- if use_slider -%}
              <div class="sis-about__slider" data-about-slider="{{ section.id }}">
                <div class="sis-about__slider-track">
                  <div class="sis-about__slider-slide sis-about__slider-slide--active">
                    <div class="sis-about__image-wrapper">
                      <img src="{{ section.settings.image | image_url: width: 1200 }}" srcset="{{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 900 }} 900w, {{ section.settings.image | image_url: width: 1200 }} 1200w" sizes="(max-width: 992px) 100vw, 50vw" alt="{{ section.settings.image_alt | escape }}" loading="lazy">
                    </div>
                  </div>
                  {%- if section.settings.image_2 != blank -%}
                    <div class="sis-about__slider-slide"><div class="sis-about__image-wrapper"><img src="{{ section.settings.image_2 | image_url: width: 1200 }}" srcset="{{ section.settings.image_2 | image_url: width: 600 }} 600w, {{ section.settings.image_2 | image_url: width: 1200 }} 1200w" sizes="(max-width: 992px) 100vw, 50vw" alt="" loading="lazy"></div></div>
                  {%- endif -%}
                  {%- if section.settings.image_3 != blank -%}
                    <div class="sis-about__slider-slide"><div class="sis-about__image-wrapper"><img src="{{ section.settings.image_3 | image_url: width: 1200 }}" srcset="{{ section.settings.image_3 | image_url: width: 600 }} 600w, {{ section.settings.image_3 | image_url: width: 1200 }} 1200w" sizes="(max-width: 992px) 100vw, 50vw" alt="" loading="lazy"></div></div>
                  {%- endif -%}
                  {%- if section.settings.image_4 != blank -%}
                    <div class="sis-about__slider-slide"><div class="sis-about__image-wrapper"><img src="{{ section.settings.image_4 | image_url: width: 1200 }}" srcset="{{ section.settings.image_4 | image_url: width: 600 }} 600w, {{ section.settings.image_4 | image_url: width: 1200 }} 1200w" sizes="(max-width: 992px) 100vw, 50vw" alt="" loading="lazy"></div></div>
                  {%- endif -%}
                  {%- if section.settings.image_5 != blank -%}
                    <div class="sis-about__slider-slide"><div class="sis-about__image-wrapper"><img src="{{ section.settings.image_5 | image_url: width: 1200 }}" srcset="{{ section.settings.image_5 | image_url: width: 600 }} 600w, {{ section.settings.image_5 | image_url: width: 1200 }} 1200w" sizes="(max-width: 992px) 100vw, 50vw" alt="" loading="lazy"></div></div>
                  {%- endif -%}
                </div>
                <button type="button" class="sis-about__slider-btn sis-about__slider-btn--prev" aria-label="Vorheriges Bild">&#10094;</button>
                <button type="button" class="sis-about__slider-btn sis-about__slider-btn--next" aria-label="Nächstes Bild">&#10095;</button>
                <div class="sis-about__slider-dots"></div>
              </div>
            {%- else -%}
              <div class="sis-about__image-wrapper">
                {% assign img = section.settings.image %}
                <img
                  src="{{ img | image_url: width: 1200 }}"
                  srcset="{{ img | image_url: width: 600 }} 600w, {{ img | image_url: width: 900 }} 900w, {{ img | image_url: width: 1200 }} 1200w"
                  sizes="(max-width: 992px) 100vw, 50vw"
                  alt="{{ section.settings.image_alt | escape }}"
                  loading="lazy">
              </div>
            {%- endif -%}
          </div>
        {%- endunless -%}
      {%- endif -%}

      <div class="sis-about__content">
        {% if title_html != blank %}
          <div class="sis-about__title rte--title">{{ title_html }}</div>
        {% endif %}
        {% if subtitle_html != blank %}
          <div class="sis-about__subtitle rte--subtitle">{{ subtitle_html }}</div>
        {% endif %}

        <div class="sis-about__description">
          {%- assign desc_html = section.settings.description -%}

          {%- if actually_show_image and float_mode -%}
            {%- capture float_markup -%}
              <div class="sis-about__image sis-about__image--float {% if img_pos == 'left' %}sis-about__image--float-left{% else %}sis-about__image--float-right{% endif %}">
                {%- if use_slider -%}
                  <div class="sis-about__slider" data-about-slider="{{ section.id }}">
                    <div class="sis-about__slider-track">
                      <div class="sis-about__slider-slide sis-about__slider-slide--active">
                        <div class="sis-about__image-wrapper"><img src="{{ section.settings.image | image_url: width: 1200 }}" srcset="{{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 1200 }} 1200w" sizes="(max-width: 992px) 100vw, 50vw" alt="{{ section.settings.image_alt | escape }}" loading="lazy"></div>
                      </div>
                      {%- if section.settings.image_2 != blank -%}<div class="sis-about__slider-slide"><div class="sis-about__image-wrapper"><img src="{{ section.settings.image_2 | image_url: width: 1200 }}" srcset="{{ section.settings.image_2 | image_url: width: 600 }} 600w, {{ section.settings.image_2 | image_url: width: 1200 }} 1200w" sizes="(max-width: 992px) 100vw, 50vw" alt="" loading="lazy"></div></div>{%- endif -%}
                      {%- if section.settings.image_3 != blank -%}<div class="sis-about__slider-slide"><div class="sis-about__image-wrapper"><img src="{{ section.settings.image_3 | image_url: width: 1200 }}" srcset="{{ section.settings.image_3 | image_url: width: 600 }} 600w, {{ section.settings.image_3 | image_url: width: 1200 }} 1200w" sizes="(max-width: 992px) 100vw, 50vw" alt="" loading="lazy"></div></div>{%- endif -%}
                      {%- if section.settings.image_4 != blank -%}<div class="sis-about__slider-slide"><div class="sis-about__image-wrapper"><img src="{{ section.settings.image_4 | image_url: width: 1200 }}" srcset="{{ section.settings.image_4 | image_url: width: 600 }} 600w, {{ section.settings.image_4 | image_url: width: 1200 }} 1200w" sizes="(max-width: 992px) 100vw, 50vw" alt="" loading="lazy"></div></div>{%- endif -%}
                      {%- if section.settings.image_5 != blank -%}<div class="sis-about__slider-slide"><div class="sis-about__image-wrapper"><img src="{{ section.settings.image_5 | image_url: width: 1200 }}" srcset="{{ section.settings.image_5 | image_url: width: 600 }} 600w, {{ section.settings.image_5 | image_url: width: 1200 }} 1200w" sizes="(max-width: 992px) 100vw, 50vw" alt="" loading="lazy"></div></div>{%- endif -%}
                    </div>
                    <button type="button" class="sis-about__slider-btn sis-about__slider-btn--prev" aria-label="Vorheriges Bild">&#10094;</button>
                    <button type="button" class="sis-about__slider-btn sis-about__slider-btn--next" aria-label="Nächstes Bild">&#10095;</button>
                    <div class="sis-about__slider-dots"></div>
                  </div>
                {%- else -%}
                  <div class="sis-about__image-wrapper">
                    {% assign img = section.settings.image %}
                    <img src="{{ img | image_url: width: 1200 }}" srcset="{{ img | image_url: width: 600 }} 600w, {{ img | image_url: width: 900 }} 900w, {{ img | image_url: width: 1200 }} 1200w" sizes="(max-width: 992px) 100vw, 50vw" alt="{{ section.settings.image_alt | escape }}" loading="lazy">
                  </div>
                {%- endif -%}
              </div>
            {%- endcapture -%}

            {%- if section.settings.image_vertical_align == 'start' -%}
              {{ float_markup }}
              {{ desc_html }}
            {%- else -%}
              {%- assign parts = desc_html | split: '</p>' -%}
              {%- assign total = parts | size -%}
              {%- if section.settings.image_vertical_align == 'end' -%}
                {%- assign insert_after = total | minus: 2 -%}
              {%- else -%}
                {%- assign insert_after = total | divided_by: 2 -%}
              {%- endif -%}
              {%- for part in parts -%}
                {%- unless part == '' -%}
                  {{ part }}</p>
                  {%- if forloop.index == insert_after -%}
                    {{ float_markup }}
                  {%- endif -%}
                {%- endunless -%}
              {%- endfor -%}
            {%- endif -%}
          {%- else -%}
            {{ desc_html }}
          {%- endif -%}
        </div>

        {% if section.blocks.size > 0 %}
          <div class="sis-about__features">
            {% for block in section.blocks %}
              <div class="sis-about__feature" id="block-{{ block.id }}" {{ block.shopify_attributes }}>
                {% render 'block-custom-styles', block: block %}
                <div class="sis-about__feature-icon">
                  {% if block.settings.icon_type == 'image' and block.settings.icon_image != blank %}
                    <img
                      src="{{ block.settings.icon_image | image_url: width: 160, height: 160 }}"
                      alt="{{ block.settings.feature_title | escape }}"
                      width="{{ section.settings.icon_size }}"
                      height="{{ section.settings.icon_size }}"
                      style="width:{{ section.settings.icon_size }}px;height:auto"
                      loading="lazy">
                  {% elsif block.settings.icon_type == 'svg' and block.settings.icon_svg != blank %}
                    {{ block.settings.icon_svg }}
                  {% endif %}
                </div>
                <div class="sis-about__feature-text">
                  <h4 class="sis-about__feature-title">{{ block.settings.feature_title }}</h4>
                  <p class="sis-about__feature-description">{{ block.settings.feature_description }}</p>
                </div>
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>

    </div>
  </div>
</div>

<style>
  /* Bild-Slider */
  .sis-about__slider { position: relative; }
  .sis-about__slider-track { position: relative; overflow: hidden; border-radius: var(--image-border-radius); }
  .sis-about__slider-slide { display: none; }
  .sis-about__slider-slide--active { display: block; }
  .sis-about__slider-slide .sis-about__image-wrapper { box-shadow: none; max-width: 100%; }
  .sis-about__slider-btn {
    position: absolute; top: 50%; transform: translateY(-50%);
    background: rgba(255,255,255,.85); border: none; border-radius: 50%;
    width: 36px; height: 36px; font-size: 18px; line-height: 1;
    cursor: pointer; z-index: 2; display: flex; align-items: center; justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,.12); transition: background .15s;
  }
  .sis-about__slider-btn:hover { background: #fff; }
  .sis-about__slider-btn--prev { left: 8px; }
  .sis-about__slider-btn--next { right: 8px; }
  .sis-about__slider-dots {
    display: flex; justify-content: center; gap: 8px; margin-top: 12px;
  }
  .sis-about__slider-dot {
    width: 10px; height: 10px; border-radius: 50%;
    background: rgba(0,0,0,.2); border: none; cursor: pointer; padding: 0;
    transition: background .15s;
  }
  .sis-about__slider-dot--active { background: rgba(0,0,0,.6); }
</style>

{%- if use_slider -%}
<script>
(function(){
  document.querySelectorAll('[data-about-slider="{{ section.id }}"]').forEach(function(slider){
    var slides = slider.querySelectorAll('.sis-about__slider-slide');
    var dotsWrap = slider.querySelector('.sis-about__slider-dots');
    var idx = 0;
    if (slides.length < 2) return;
    slides.forEach(function(_, i){
      var dot = document.createElement('button');
      dot.className = 'sis-about__slider-dot' + (i === 0 ? ' sis-about__slider-dot--active' : '');
      dot.setAttribute('aria-label', 'Bild ' + (i + 1));
      dot.addEventListener('click', function(){ goTo(i); });
      dotsWrap.appendChild(dot);
    });
    function goTo(n){
      slides[idx].classList.remove('sis-about__slider-slide--active');
      dotsWrap.children[idx].classList.remove('sis-about__slider-dot--active');
      idx = (n + slides.length) % slides.length;
      slides[idx].classList.add('sis-about__slider-slide--active');
      dotsWrap.children[idx].classList.add('sis-about__slider-dot--active');
    }
    slider.querySelector('.sis-about__slider-btn--prev').addEventListener('click', function(){ goTo(idx - 1); });
    slider.querySelector('.sis-about__slider-btn--next').addEventListener('click', function(){ goTo(idx + 1); });
    var autoplay = {{ section.settings.slider_autoplay | default: 0 }};
    if (autoplay > 0) setInterval(function(){ goTo(idx + 1); }, autoplay * 1000);
  });
})();
</script>
{%- endif -%}

<script>
/* Optional: Höhe an vorherigen Abschnitt angleichen */
(function() {
  var enabled = {{ section.settings.match_prev_height | json }};
  if (!enabled) return;

  var minWidth = {{ section.settings.match_min_width | json }};
  var offset = {{ section.settings.match_prev_height_offset | json }};

  var root = document.getElementById('about-{{ section.id }}');
  if (!root) return;

  var grid = root.querySelector('.sis-about__grid');
  if (!grid) return;

  function findPrevSection(el){
    var prev = el.previousElementSibling;
    while(prev && prev.offsetHeight === 0){ prev = prev.previousElementSibling; }
    return prev;
  }
  function apply() {
    if (window.innerWidth < (minWidth || 0)) {
      grid.style.removeProperty('--about-match-height');
      return;
    }
    var prev = findPrevSection(root.parentElement || root);
    if (!prev) return;
    var h = prev.getBoundingClientRect().height - (offset || 0);
    if (h > 0) grid.style.setProperty('--about-match-height', h + 'px');
  }
  apply();
  window.addEventListener('load', apply);
  window.addEventListener('resize', apply);
  setTimeout(apply, 400);
  setTimeout(apply, 1200);
})();
</script>

{% schema %}
{
  "name": "Über Uns (Layout) – v3",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "image_position",
      "label": "Bild-Position",
      "options": [
        {
          "value": "right",
          "label": "Text links, Bild rechts (Text umfließt Bild)"
        },
        {
          "value": "left",
          "label": "Bild links, Text rechts (Text umfließt Bild)"
        },
        {
          "value": "top",
          "label": "Bild oben (volle Breite)"
        },
        {
          "value": "bottom",
          "label": "Bild unten (volle Breite)"
        }
      ],
      "default": "right"
    },
    {
      "type": "select",
      "id": "image_vertical_align",
      "label": "Ausrichtung bei links/rechts (Einfügeposition im Text)",
      "options": [
        {
          "value": "start",
          "label": "Oben (direkt am Anfang)"
        },
        {
          "value": "center",
          "label": "Mittig (nach ca. der Hälfte)"
        },
        {
          "value": "end",
          "label": "Unten (vor letztem Absatz)"
        }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Bild anzeigen",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Hintergrundfarbe",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Abstand oben",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Abstand unten",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titel (Fallback)",
      "default": "Über uns"
    },
    {
      "type": "richtext",
      "id": "title_richtext",
      "label": "Titel (Richtext)",
      "default": "<p><strong>Über uns</strong></p>"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Titel Farbe",
      "default": "#111827"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Titel Schriftgröße",
      "min": 20,
      "max": 56,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Untertitel (Fallback)",
      "default": "Unsere Mission"
    },
    {
      "type": "richtext",
      "id": "subtitle_richtext",
      "label": "Untertitel (Richtext)",
      "default": "<p>Unsere Mission</p>"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Untertitel Farbe",
      "default": "#374151"
    },
    {
      "type": "range",
      "id": "subtitle_font_size",
      "label": "Untertitel Schriftgröße",
      "min": 16,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Beschreibungstext",
