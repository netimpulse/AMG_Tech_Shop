{% comment %}
  Section: Safety / Hinweis-Box
{% endcomment %}
{{ 'safety-info.css' | asset_url | stylesheet_tag }}

<section
  id="safety-info-{{ section.id }}"
  class="safety-info-wrapper"
  style="
    --si-background: {{ section.settings.background_color }};
    --si-card-bg: {{ section.settings.card_background_color }};
    --si-border: {{ section.settings.card_border_color }};
    --si-border-hover: {{ section.settings.card_border_hover_color }};
    --si-padding-y: {{ section.settings.padding_y | default: 48 }}px;
    --si-title-size: {{ section.settings.title_font_size | default: 18 }}px;
    --si-text-size: {{ section.settings.text_font_size | default: 16 }}px;
    --si-icon-size: {{ section.settings.icon_size | default: 48 }}px;
    --si-card-padding: {{ section.settings.card_padding | default: 24 }}px;
  "
>
  <div class="page-width">
    <div class="safety-info-list">
      {% for block in section.blocks %}
        {% render 'safety-info-card', block: block, section: section %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Sicherheits-Hinweis Box",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Hintergrundfarbe Section",
      "default": "#EFF3F6"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Box-Hintergrund",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Rahmenfarbe",
      "default": "#B3E6F1"
    },
    {
      "type": "color",
      "id": "card_border_hover_color",
      "label": "Rahmenfarbe bei Hover",
      "default": "#5ED7F2"
    },
    {
      "type": "header",
      "content": "━━ Groessen ━━"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Abstand oben/unten (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Box-Innenabstand (px)",
      "min": 8,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon-Groesse (px)",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Titel-Schriftgroesse (px)",
      "min": 12,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "text_font_size",
      "label": "Text-Schriftgroesse (px)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "info",
      "name": "Hinweis-Box",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Überschrift (Richtext)",
          "default": "<p><strong>Sicherer Umgang mit Trockeneis</strong></p>"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text (Richtext)",
          "default": "<p>Trockeneis ist ein sicheres Kühlmittel, erfordert aber sachgerechte Handhabung. Wichtig: <strong>immer gut belüften</strong> und <strong>Schutzhandschuhe tragen</strong>, um Hautverbrennungen zu vermeiden. Niemals in geschlossenen Räumen ohne Belüftung lagern.</p>"
        },
        {
          "type": "checkbox",
          "id": "show_button",
          "label": "Button anzeigen",
          "default": true
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button-Text",
          "default": "Zu den Sicherheitsinformationen"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button-Link"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Sicherheits-Hinweis Box",
      "blocks": [
        {
          "type": "info"
        }
      ]
    }
  ]
}
{% endschema %}
