{%- assign _fs = section.settings.block_font_size -%}
{%- assign _fc = section.settings.block_font_color -%}
{%- assign _ff = section.settings.block_font_family -%}
{%- assign _bg = section.settings.block_bg_color -%}
{%- if _fs > 0 or _fc != blank or _ff or _bg != blank -%}
<style>
  #shopify-section-{{ section.id }} .sec-inner {
    {%- if _fs > 0 -%}font-size: {{ _fs }}px;{%- endif -%}
    {%- if _fc != blank -%}color: {{ _fc }};{%- endif -%}
    {%- if _ff -%}font-family: {{ _ff.family }}, {{ _ff.fallback_families }};font-weight: {{ _ff.weight }};font-style: {{ _ff.style }};{%- endif -%}
    {%- if _bg != blank -%}background: {{ _bg }};{%- endif -%}
  }
</style>
{%- endif -%}

{{ 'mod-marquee.css' | asset_url | stylesheet_tag }}
{%- assign s = section.settings -%}
<div class="mmq sec-inner" style="{%- if s.section_bg != blank -%}background:{{ s.section_bg }};{%- endif -%}padding:{{ s.padding_y }}px 0;">
  <div class="mmq__track" style="animation-duration:{{ s.speed }}s;{%- if s.text_color != blank -%}color:{{ s.text_color }};{%- endif -%}">
    {%- for i in (1..3) -%}
      <span class="mmq__text" style="font-size:{{ s.font_size }}px;">
        {%- for block in section.blocks -%}
          <span class="mmq__item">{{ block.settings.text }}</span>
          {%- if s.separator != blank -%}<span class="mmq__sep">{{ s.separator }}</span>{%- endif -%}
        {%- endfor -%}
      </span>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Mod: Lauftext",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "separator",
      "label": "Trennzeichen",
      "default": "✦"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Schriftgroesse (px)",
      "min": 12,
      "max": 72,
      "step": 2,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Geschwindigkeit (Sekunden)",
      "min": 5,
      "max": 60,
      "step": 5,
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Abstand (px)",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "color_background",
      "id": "section_bg",
      "label": "Hintergrund"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Textfarbe"
    },
    {
      "type": "header",
      "content": "━━ Styling ━━"
    },
    {
      "type": "range",
      "id": "block_font_size",
      "label": "Schriftgroesse (px)",
      "min": 0,
      "max": 72,
      "step": 1,
      "default": 0,
      "unit": "px",
      "info": "0 = Standard"
    },
    {
      "type": "color",
      "id": "block_font_color",
      "label": "Schriftfarbe"
    },
    {
      "type": "font_picker",
      "id": "block_font_family",
      "label": "Schriftart",
      "default": "assistant_n4"
    },
    {
      "type": "color_background",
      "id": "block_bg_color",
      "label": "Block-Hintergrundfarbe"
    }
  ],
  "blocks": [
    {
      "type": "text_item",
      "name": "Text-Element",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Kostenloser Versand"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mod: Lauftext",
      "blocks": [
        {
          "type": "text_item",
          "settings": {
            "text": "Kostenloser Versand"
          }
        },
        {
          "type": "text_item",
          "settings": {
            "text": "30 Tage Rueckgabe"
          }
        },
        {
          "type": "text_item",
          "settings": {
            "text": "Sichere Zahlung"
          }
        }
      ]
    }
  ]
}
{% endschema %}