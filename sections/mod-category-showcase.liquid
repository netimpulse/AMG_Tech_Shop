{%- assign _fs = section.settings.block_font_size -%}
{%- assign _fc = section.settings.block_font_color -%}
{%- assign _ff = section.settings.block_font_family -%}
{%- assign _bg = section.settings.block_bg_color -%}
{%- assign _tfs = section.settings.title_font_size -%}
{%- assign _tfc = section.settings.title_font_color -%}
{%- assign _stfs = section.settings.subtitle_font_size -%}
<style>
  {%- if _fs > 0 or _fc != blank or _ff or _bg != blank -%}
  #shopify-section-{{ section.id }} .sec-inner {
    {%- if _fs > 0 -%}font-size: {{ _fs }}px;{%- endif -%}
    {%- if _fc != blank -%}color: {{ _fc }};{%- endif -%}
    {%- if _ff -%}font-family: {{ _ff.family }}, {{ _ff.fallback_families }};font-weight: {{ _ff.weight }};font-style: {{ _ff.style }};{%- endif -%}
    {%- if _bg != blank -%}background: {{ _bg }};{%- endif -%}
  }
  {%- endif -%}
  {%- if _tfs > 0 -%}
  #shopify-section-{{ section.id }} .mcs__title { font-size: {{ _tfs }}px; }
  {%- endif -%}
  {%- if _tfc != blank -%}
  #shopify-section-{{ section.id }} .mcs__title { color: {{ _tfc }}; }
  {%- endif -%}
  {%- if _stfs > 0 -%}
  #shopify-section-{{ section.id }} .mcs__subtitle { font-size: {{ _stfs }}px; }
  {%- endif -%}
  #shopify-section-{{ section.id }} .mcs__heading { {%- if section.settings.heading_font_size > 0 -%}font-size: {{ section.settings.heading_font_size }}px;{%- endif -%} }
</style>

{{ 'mod-category-showcase.css' | asset_url | stylesheet_tag }}
{%- assign s = section.settings -%}
<div class="mcs sec-inner" style="padding:{{ s.padding_y }}px 0;{%- if s.section_bg != blank -%}background:{{ s.section_bg }};{%- endif -%}">
  <div class="page-width">
    {%- if s.heading != blank -%}<h2 class="mcs__heading">{{ s.heading }}</h2>{%- endif -%}
    <div class="mcs__grid mcs__grid--{{ section.blocks.size | at_most: 4 }}">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="mcs__card" {{ block.shopify_attributes }} id="block-{{ block.id }}">
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | escape }}" class="mcs__image" loading="lazy">
          {%- else -%}
            <div class="mcs__image mcs__image--placeholder"></div>
          {%- endif -%}
          <div class="mcs__overlay">
            <span class="mcs__title">{{ block.settings.title }}</span>
            {%- if block.settings.subtitle != blank -%}<span class="mcs__subtitle">{{ block.settings.subtitle }}</span>{%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Mod: Kategorie-Kacheln",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Ueberschrift",
      "default": "Unsere Kategorien"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Abstand (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "color_background",
      "id": "section_bg",
      "label": "Sektions-Hintergrund"
    },
    {
      "type": "header",
      "content": "━━ Ueberschrift ━━"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Ueberschrift Schriftgroesse (px)",
      "min": 0,
      "max": 72,
      "step": 1,
      "default": 0,
      "unit": "px",
      "info": "0 = Standard"
    },
    {
      "type": "header",
      "content": "━━ Kachel-Titel ━━"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Kachel-Titel Schriftgroesse (px)",
      "min": 0,
      "max": 48,
      "step": 1,
      "default": 0,
      "unit": "px",
      "info": "0 = Standard"
    },
    {
      "type": "color",
      "id": "title_font_color",
      "label": "Kachel-Titel Farbe"
    },
    {
      "type": "range",
      "id": "subtitle_font_size",
      "label": "Kachel-Untertitel Schriftgroesse (px)",
      "min": 0,
      "max": 36,
      "step": 1,
      "default": 0,
      "unit": "px",
      "info": "0 = Standard"
    },
    {
      "type": "header",
      "content": "━━ Styling ━━"
    },
    {
      "type": "range",
      "id": "block_font_size",
      "label": "Schriftgroesse (px)",
      "min": 0,
      "max": 72,
      "step": 1,
      "default": 0,
      "unit": "px",
      "info": "0 = Standard"
    },
    {
      "type": "color",
      "id": "block_font_color",
      "label": "Schriftfarbe"
    },
    {
      "type": "font_picker",
      "id": "block_font_family",
      "label": "Schriftart",
      "default": "assistant_n4"
    },
    {
      "type": "color_background",
      "id": "block_bg_color",
      "label": "Block-Hintergrundfarbe"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Kategorie",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bild"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Kategorie"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Untertitel"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "header",
          "content": "Block-Styling"
        },
        {
          "type": "range",
          "id": "block_font_size",
          "label": "Schriftgroesse (px)",
          "min": 0,
          "max": 72,
          "step": 1,
          "default": 0,
          "unit": "px",
          "info": "0 = Standard"
        },
        {
          "type": "color",
          "id": "block_font_color",
          "label": "Schriftfarbe"
        },
        {
          "type": "font_picker",
          "id": "block_font_family",
          "label": "Schriftart",
          "default": "assistant_n4"
        },
        {
          "type": "color_background",
          "id": "block_bg_color",
          "label": "Hintergrundfarbe"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mod: Kategorie-Kacheln",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Bestseller"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Neuheiten"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Angebote"
          }
        }
      ]
    }
  ]
}
{% endschema %}