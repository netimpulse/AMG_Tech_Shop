{%- assign _fs = section.settings.block_font_size -%}
{%- assign _fc = section.settings.block_font_color -%}
{%- assign _ff = section.settings.block_font_family -%}
{%- assign _bg = section.settings.block_bg_color -%}
{%- if _fs > 0 or _fc != blank or _ff or _bg != blank -%}
<style>
  #shopify-section-{{ section.id }} .sec-inner {
    {%- if _fs > 0 -%}font-size: {{ _fs }}px;{%- endif -%}
    {%- if _fc != blank -%}color: {{ _fc }};{%- endif -%}
    {%- if _ff -%}font-family: {{ _ff.family }}, {{ _ff.fallback_families }};font-weight: {{ _ff.weight }};font-style: {{ _ff.style }};{%- endif -%}
    {%- if _bg != blank -%}background: {{ _bg }};{%- endif -%}
  }
</style>
{%- endif -%}

{{ 'mod-video-showcase.css' | asset_url | stylesheet_tag }}
{%- assign s = section.settings -%}
<div class="mvs sec-inner" style="padding:{{ s.padding_y }}px 0;{%- if s.section_bg != blank -%}background:{{ s.section_bg }};{%- endif -%}">
  <div class="page-width mvs__inner">
    {%- if s.heading != blank -%}<h2 class="mvs__heading">{{ s.heading }}</h2>{%- endif -%}
    {%- if s.subheading != blank -%}<p class="mvs__sub">{{ s.subheading }}</p>{%- endif -%}
    <div class="mvs__wrapper" style="max-width:{{ s.max_width }}px;margin:0 auto;">
      {%- if s.video_url != blank -%}
        {%- if s.video_url contains 'youtube' or s.video_url contains 'youtu.be' -%}
          {%- assign yt_id = s.video_url | split: 'v=' | last | split: '&' | first -%}
          {%- if s.video_url contains 'youtu.be' -%}{%- assign yt_id = s.video_url | split: 'youtu.be/' | last | split: '?' | first -%}{%- endif -%}
          <div class="mvs__ratio"><iframe src="https://www.youtube.com/embed/{{ yt_id }}" frameborder="0" allowfullscreen loading="lazy" class="mvs__iframe"></iframe></div>
        {%- elsif s.video_url contains 'vimeo' -%}
          {%- assign vm_id = s.video_url | split: 'vimeo.com/' | last | split: '?' | first -%}
          <div class="mvs__ratio"><iframe src="https://player.vimeo.com/video/{{ vm_id }}" frameborder="0" allowfullscreen loading="lazy" class="mvs__iframe"></iframe></div>
        {%- endif -%}
      {%- elsif s.hosted_video != blank -%}
        <video class="mvs__video" controls {% if s.autoplay %}autoplay muted{% endif %} {% if s.loop %}loop{% endif %} playsinline poster="{{ s.poster | image_url: width: 1200 }}">
          <source src="{{ s.hosted_video }}" type="video/mp4">
        </video>
      {%- else -%}
        <div class="mvs__placeholder">Video-URL im Editor einfuegen</div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Mod: Video Showcase",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Ueberschrift"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Unterueberschrift"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "YouTube / Vimeo URL"
    },
    {
      "type": "video_url",
      "id": "hosted_video",
      "label": "Eigenes Video (MP4)",
      "accept": [
        "youtube",
        "vimeo"
      ]
    },
    {
      "type": "image_picker",
      "id": "poster",
      "label": "Poster-Bild (fuer eigenes Video)"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay (stumm)",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Endlosschleife",
      "default": false
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximale Breite (px)",
      "min": 400,
      "max": 1400,
      "step": 50,
      "default": 900,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Abstand (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "color_background",
      "id": "section_bg",
      "label": "Sektions-Hintergrund"
    },
    {
      "type": "header",
      "content": "━━ Styling ━━"
    },
    {
      "type": "range",
      "id": "block_font_size",
      "label": "Schriftgroesse (px)",
      "min": 0,
      "max": 72,
      "step": 1,
      "default": 0,
      "unit": "px",
      "info": "0 = Standard"
    },
    {
      "type": "color",
      "id": "block_font_color",
      "label": "Schriftfarbe"
    },
    {
      "type": "font_picker",
      "id": "block_font_family",
      "label": "Schriftart",
      "default": "assistant_n4"
    },
    {
      "type": "color_background",
      "id": "block_bg_color",
      "label": "Block-Hintergrundfarbe"
    }
  ],
  "presets": [
    {
      "name": "Mod: Video Showcase"
    }
  ]
}
{% endschema %}