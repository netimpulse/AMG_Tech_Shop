    { "type": "text", "id": "express_box_note", "label": "Hinweis Box bei Express", "default": "Expressversand erfolgt immer inkl. isolierter Thermobox." },

    { "type": "header", "content": "Verpackung (Selbstabholung)" },
    { "type": "text", "id": "box_heading", "label": "Überschrift", "default": "Verpackung wählen" },
    { "type": "text", "id": "box_with_desc", "label": "Beschreibung: Mit Box", "default": "Gesamtpreis inkl. isolierter Thermobox" },
    { "type": "text", "id": "box_own_desc", "label": "Beschreibung: Eigene Box", "default": "Sie bringen Ihre eigene Isolierbox zur Abholung mit" },
    { "type": "text", "id": "box_save_label", "label": "Erspernis-Label", "default": "Sie sparen" },

    { "type": "header", "content": "Mengen auf Anfrage" },
