    ] },
    { "type": "checkbox", "id": "enable_pickup", "label": "Selbstabholung anbieten", "default": true, "info": "Kann zusätzlich pro Produkt/Variante über das Metafield custom.selbstabholung gesteuert werden." },
    { "type": "text", "id": "pickup_title", "label": "Selbstabholung: Titel", "default": "Selbstabholung" },
    { "type": "text", "id": "pickup_desc", "label": "Selbstabholung: Beschreibung", "default": "Abholung an unserem Standort in Völklingen" },
    { "type": "text", "id": "pickup_free_label", "label": "Selbstabholung: Preis-Label", "default": "Kostenlos" },
    { "type": "checkbox", "id": "enable_express", "label": "Expresslieferung anbieten", "default": true, "info": "Kann zusätzlich pro Produkt/Variante über das Metafield custom.expresslieferung gesteuert werden." },
    { "type": "text", "id": "express_title", "label": "Express: Titel", "default": "Expresslieferung" },
