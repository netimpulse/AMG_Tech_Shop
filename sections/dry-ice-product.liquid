    { "type": "text", "id": "more_label", "label": "Button-Text", "default": "Mehr auf Anfrage" },
    { "type": "text", "id": "anfrage_title", "label": "Hinweis: Titel", "default": "Größere Mengen gewünscht?" },
    { "type": "text", "id": "anfrage_text", "label": "Hinweis: Text", "default": "Kontaktieren Sie uns für ein individuelles Angebot." },
    { "type": "text", "id": "anfrage_button", "label": "Hinweis: Button", "default": "Kontakt aufnehmen" },
    { "type": "url", "id": "contact_page", "label": "Kontaktseite" },

    { "type": "header", "content": "Warenkorb" },
    { "type": "text", "id": "atc_label", "label": "Button-Text", "default": "In den Warenkorb" },
    { "type": "text", "id": "sold_out_label", "label": "Ausverkauft-Text", "default": "Ausverkauft" },
