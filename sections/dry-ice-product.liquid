    { "type": "color", "id": "accent_color", "label": "Akzentfarbe", "default": "#1d4ed8" },
    { "type": "checkbox", "id": "sort_numeric", "label": "Numerische Optionswerte sortieren", "default": true, "info": "Sortiert z. B. Gewichte aufsteigend (1KG, 2KG, ... 15KG), unabhängig von der Reihenfolge im Admin." },

    { "type": "header", "content": "Lieferung" },
