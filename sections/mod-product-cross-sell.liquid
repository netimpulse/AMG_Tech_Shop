{%- assign _fs = section.settings.block_font_size -%}
{%- assign _fc = section.settings.block_font_color -%}
{%- assign _ff = section.settings.block_font_family -%}
{%- assign _bg = section.settings.block_bg_color -%}
{%- if _fs > 0 or _fc != blank or _ff or _bg != blank -%}
<style>
  #shopify-section-{{ section.id }} .sec-inner {
    {%- if _fs > 0 -%}font-size: {{ _fs }}px;{%- endif -%}
    {%- if _fc != blank -%}color: {{ _fc }};{%- endif -%}
    {%- if _ff -%}font-family: {{ _ff.family }}, {{ _ff.fallback_families }};font-weight: {{ _ff.weight }};font-style: {{ _ff.style }};{%- endif -%}
    {%- if _bg != blank -%}background: {{ _bg }};{%- endif -%}
  }
</style>
{%- endif -%}

{{ 'mod-product-cross-sell.css' | asset_url | stylesheet_tag }}
{%- assign s = section.settings -%}
<div class="mxs sec-inner" style="padding:{{ s.padding_y }}px 0;{%- if s.section_bg != blank -%}background:{{ s.section_bg }};{%- endif -%}">
  <div class="page-width">
    <h2 class="mxs__heading">{{ s.heading }}</h2>
    {%- if s.subheading != blank -%}<p class="mxs__sub">{{ s.subheading }}</p>{%- endif -%}
    <div class="mxs__grid">
      {%- for block in section.blocks -%}
        {%- assign p = block.settings.product -%}
        {%- if p != blank -%}
        <div class="mxs__card" {{ block.shopify_attributes }}>
          <a href="{{ p.url }}" class="mxs__link">
            <div class="mxs__img-wrap">
              {%- if p.featured_image != blank -%}
                <img src="{{ p.featured_image | image_url: width: 500 }}" alt="{{ p.featured_image.alt | escape }}" loading="lazy" class="mxs__img" width="500" height="{{ 500 | divided_by: p.featured_image.aspect_ratio | round }}">
              {%- endif -%}
              {%- if p.compare_at_price > p.price -%}
                <span class="mxs__badge">-{{ p.compare_at_price | minus: p.price | times: 100 | divided_by: p.compare_at_price }}%</span>
              {%- endif -%}
            </div>
            <div class="mxs__info">
              <span class="mxs__title">{{ p.title }}</span>
              <span class="mxs__price">
                {%- if p.compare_at_price > p.price -%}<s class="mxs__old">{{ p.compare_at_price | money }}</s>{%- endif -%}
                {{ p.price | money }}
              </span>
            </div>
          </a>
          {%- if p.available and p.variants.size == 1 -%}
          <form method="post" action="/cart/add" class="mxs__form">
            <input type="hidden" name="id" value="{{ p.first_available_variant.id }}">
            <button type="submit" class="mxs__add">+</button>
          </form>
          {%- endif -%}
        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Mod: Cross-Sell Produkte",
  "tag": "section",
  "class": "section-mod-cross-sell",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Ueberschrift",
      "default": "Das koennte dir auch gefallen"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Unterueberschrift"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Abstand (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Hintergrundfarbe"
    },
    {
      "type": "header",
      "content": "Globale Schrift & Farbe"
    },
    {
      "type": "range",
      "id": "block_font_size",
      "label": "Schriftgroesse (px)",
      "min": 0,
      "max": 72,
      "step": 1,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "block_font_color",
      "label": "Schriftfarbe"
    },
    {
      "type": "font_picker",
      "id": "block_font_family",
      "label": "Schriftart",
      "default": "assistant_n4"
    },
    {
      "type": "color_background",
      "id": "block_bg_color",
      "label": "Abschnitt-Hintergrund"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Produkt",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Produkt"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mod: Cross-Sell Produkte",
      "blocks": [
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        }
      ]
    }
  ]
}
{% endschema %}
