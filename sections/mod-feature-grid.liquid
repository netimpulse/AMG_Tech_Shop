{%- assign _fs = section.settings.block_font_size -%}
{%- assign _fc = section.settings.block_font_color -%}
{%- assign _ff = section.settings.block_font_family -%}
{%- assign _bg = section.settings.block_bg_color -%}
{%- if _fs > 0 or _fc != blank or _ff or _bg != blank -%}
<style>
  #shopify-section-{{ section.id }} .sec-inner {
    {%- if _fs > 0 -%}font-size: {{ _fs }}px;{%- endif -%}
    {%- if _fc != blank -%}color: {{ _fc }};{%- endif -%}
    {%- if _ff -%}font-family: {{ _ff.family }}, {{ _ff.fallback_families }};font-weight: {{ _ff.weight }};font-style: {{ _ff.style }};{%- endif -%}
    {%- if _bg != blank -%}background: {{ _bg }};{%- endif -%}
  }
</style>
{%- endif -%}

{{ 'mod-feature-grid.css' | asset_url | stylesheet_tag }}
{%- assign s = section.settings -%}
<div class="mfg sec-inner" style="padding:{{ s.padding_y }}px 0;{%- if s.section_bg != blank -%}background:{{ s.section_bg }};{%- endif -%}">
  <div class="page-width">
    {%- if s.heading != blank -%}<h2 class="mfg__heading">{{ s.heading }}</h2>{%- endif -%}
    {%- if s.subheading != blank -%}<p class="mfg__sub">{{ s.subheading }}</p>{%- endif -%}
    <div class="mfg__grid mfg__grid--{{ s.columns }}">
      {%- for block in section.blocks -%}
        <div class="mfg__item" {{ block.shopify_attributes }} id="block-{{ block.id }}">
          {%- if block.settings.icon_image != blank -%}
            <img src="{{ block.settings.icon_image | image_url: width: 96 }}" alt="" class="mfg__icon" width="48" height="48" loading="lazy">
          {%- elsif block.settings.icon_emoji != blank -%}
            <span class="mfg__emoji">{{ block.settings.icon_emoji }}</span>
          {%- endif -%}
          {%- if block.settings.title != blank -%}<h3 class="mfg__title">{{ block.settings.title }}</h3>{%- endif -%}
          {%- if block.settings.text != blank -%}<p class="mfg__text">{{ block.settings.text }}</p>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Mod: Feature Grid",
  "tag": "section",
  "class": "section-mod-feature-grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Ueberschrift"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Unterueberschrift"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Spalten",
      "options": [
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        },
        {
          "value": "4",
          "label": "4"
        }
      ],
      "default": "3"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Abstand oben/unten (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "color_background",
      "id": "section_bg",
      "label": "Sektions-Hintergrund"
    },
    {
      "type": "header",
      "content": "━━ Styling ━━"
    },
    {
      "type": "range",
      "id": "block_font_size",
      "label": "Schriftgroesse (px)",
      "min": 0,
      "max": 72,
      "step": 1,
      "default": 0,
      "unit": "px",
      "info": "0 = Standard"
    },
    {
      "type": "color",
      "id": "block_font_color",
      "label": "Schriftfarbe"
    },
    {
      "type": "font_picker",
      "id": "block_font_family",
      "label": "Schriftart",
      "default": "assistant_n4"
    },
    {
      "type": "color_background",
      "id": "block_bg_color",
      "label": "Block-Hintergrundfarbe"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon (Bild)"
        },
        {
          "type": "text",
          "id": "icon_emoji",
          "label": "Icon (Emoji/Text, falls kein Bild)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Feature"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Beschreibung"
        },
        {
          "type": "header",
          "content": "Block-Styling"
        },
        {
          "type": "range",
          "id": "block_font_size",
          "label": "Schriftgroesse (px)",
          "min": 0,
          "max": 72,
          "step": 1,
          "default": 0,
          "unit": "px",
          "info": "0 = Standard"
        },
        {
          "type": "color",
          "id": "block_font_color",
          "label": "Schriftfarbe"
        },
        {
          "type": "font_picker",
          "id": "block_font_family",
          "label": "Schriftart",
          "default": "assistant_n4"
        },
        {
          "type": "color_background",
          "id": "block_bg_color",
          "label": "Hintergrundfarbe"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mod: Feature Grid",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Kostenloser Versand",
            "text": "Ab 50 EUR Bestellwert"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "30 Tage Rueckgabe",
            "text": "Problemlose Ruecksendung"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Sichere Zahlung",
            "text": "SSL-verschluesselt"
          }
        }
      ]
    }
  ]
}
{% endschema %}