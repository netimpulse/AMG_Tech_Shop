{%- assign _fs = section.settings.block_font_size -%}
{%- assign _fc = section.settings.block_font_color -%}
{%- assign _ff = section.settings.block_font_family -%}
{%- assign _bg = section.settings.block_bg_color -%}
{%- if _fs > 0 or _fc != blank or _ff or _bg != blank -%}
<style>
  #shopify-section-{{ section.id }} .sec-inner {
    {%- if _fs > 0 -%}font-size: {{ _fs }}px;{%- endif -%}
    {%- if _fc != blank -%}color: {{ _fc }};{%- endif -%}
    {%- if _ff -%}font-family: {{ _ff.family }}, {{ _ff.fallback_families }};font-weight: {{ _ff.weight }};font-style: {{ _ff.style }};{%- endif -%}
    {%- if _bg != blank -%}background: {{ _bg }};{%- endif -%}
  }
</style>
{%- endif -%}

{{ 'mod-newsletter.css' | asset_url | stylesheet_tag }}
{%- assign s = section.settings -%}
<div class="mnl sec-inner" style="padding:{{ s.padding_y }}px 0;{%- if s.section_bg != blank -%}background:{{ s.section_bg }};{%- endif -%}">
  <div class="page-width mnl__inner">
    {%- if s.heading != blank -%}<h2 class="mnl__heading">{{ s.heading }}</h2>{%- endif -%}
    {%- if s.text != blank -%}<p class="mnl__text">{{ s.text }}</p>{%- endif -%}
    {%- form 'customer', class: 'mnl__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="mnl__row">
        <input type="email" name="contact[email]" class="mnl__input" placeholder="{{ s.placeholder | default: 'Ihre E-Mail-Adresse' }}" required autocomplete="email">
        <button type="submit" class="mnl__btn button">{{ s.btn_text | default: 'Anmelden' }}</button>
      </div>
      {%- if s.disclaimer != blank -%}<p class="mnl__disclaimer">{{ s.disclaimer }}</p>{%- endif -%}
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Mod: Newsletter",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Ueberschrift",
      "default": "Newsletter abonnieren"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Beschreibung",
      "default": "Erhalten Sie exklusive Angebote und Neuigkeiten."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "E-Mail Platzhalter",
      "default": "Ihre E-Mail-Adresse"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button-Text",
      "default": "Anmelden"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Hinweistext",
      "default": "Mit der Anmeldung stimmen Sie unserer Datenschutzerklaerung zu."
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Abstand (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "color_background",
      "id": "section_bg",
      "label": "Sektions-Hintergrund"
    },
    {
      "type": "header",
      "content": "━━ Styling ━━"
    },
    {
      "type": "range",
      "id": "block_font_size",
      "label": "Schriftgroesse (px)",
      "min": 0,
      "max": 72,
      "step": 1,
      "default": 0,
      "unit": "px",
      "info": "0 = Standard"
    },
    {
      "type": "color",
      "id": "block_font_color",
      "label": "Schriftfarbe"
    },
    {
      "type": "font_picker",
      "id": "block_font_family",
      "label": "Schriftart",
      "default": "assistant_n4"
    },
    {
      "type": "color_background",
      "id": "block_bg_color",
      "label": "Block-Hintergrundfarbe"
    }
  ],
  "presets": [
    {
      "name": "Mod: Newsletter"
    }
  ]
}
{% endschema %}