{%- assign _fs = section.settings.block_font_size -%}
{%- assign _fc = section.settings.block_font_color -%}
{%- assign _ff = section.settings.block_font_family -%}
{%- assign _bg = section.settings.block_bg_color -%}
{%- if _fs > 0 or _fc != blank or _ff or _bg != blank -%}
<style>
  #shopify-section-{{ section.id }} .sec-inner {
    {%- if _fs > 0 -%}font-size: {{ _fs }}px;{%- endif -%}
    {%- if _fc != blank -%}color: {{ _fc }};{%- endif -%}
    {%- if _ff -%}font-family: {{ _ff.family }}, {{ _ff.fallback_families }};font-weight: {{ _ff.weight }};font-style: {{ _ff.style }};{%- endif -%}
    {%- if _bg != blank -%}background: {{ _bg }};{%- endif -%}
  }
</style>
{%- endif -%}

{{ 'mod-logo-bar.css' | asset_url | stylesheet_tag }}
{%- assign s = section.settings -%}
<div class="mlb sec-inner" style="padding:{{ s.padding_y }}px 0;{%- if s.section_bg != blank -%}background:{{ s.section_bg }};{%- endif -%}">
  <div class="page-width">
    {%- if s.heading != blank -%}<p class="mlb__heading">{{ s.heading }}</p>{%- endif -%}
    <div class="mlb__grid">
      {%- for block in section.blocks -%}
        <div class="mlb__item" {{ block.shopify_attributes }}>
          {%- if block.settings.logo != blank -%}
            {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}" target="_blank" rel="noopener">{%- endif -%}
            <img src="{{ block.settings.logo | image_url: width: 200 }}" alt="{{ block.settings.logo.alt | escape }}" class="mlb__logo" loading="lazy" style="max-height:{{ s.logo_height }}px;">
            {%- if block.settings.link != blank -%}</a>{%- endif -%}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Mod: Logo-Leiste",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Ueberschrift",
      "default": "Bekannt aus"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo-Hoehe (px)",
      "min": 20,
      "max": 120,
      "step": 5,
      "default": 50,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Abstand (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "color_background",
      "id": "section_bg",
      "label": "Sektions-Hintergrund"
    },
    {
      "type": "header",
      "content": "━━ Styling ━━"
    },
    {
      "type": "range",
      "id": "block_font_size",
      "label": "Schriftgroesse (px)",
      "min": 0,
      "max": 72,
      "step": 1,
      "default": 0,
      "unit": "px",
      "info": "0 = Standard"
    },
    {
      "type": "color",
      "id": "block_font_color",
      "label": "Schriftfarbe"
    },
    {
      "type": "font_picker",
      "id": "block_font_family",
      "label": "Schriftart",
      "default": "assistant_n4"
    },
    {
      "type": "color_background",
      "id": "block_bg_color",
      "label": "Block-Hintergrundfarbe"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mod: Logo-Leiste"
    }
  ]
}
{% endschema %}